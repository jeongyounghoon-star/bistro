{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "KR: collect data (Naver + data.go.kr)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/collect_kr_data.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "KR: run forecasts → forecasts.json",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_kr_forecasts.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "KR: forecast single id (kr_cpi_yoy)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_kr_forecasts.py",
      "args": ["--ids", "kr_cpi_yoy"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
