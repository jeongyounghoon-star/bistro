# Copy to .env and fill in values. Never commit .env.

# data.go.kr Open API (공공데이터포탈) service key
# Issue at https://www.data.go.kr
DATA_GO_KR_API_KEY=your-service-key-here

# 한국은행 ECOS Open API key
# Issue at https://ecos.bok.or.kr
BOK_API_KEY=your-ecos-key-here

# Optional: override output directories
KR_DATA_DIR=data/kr
KR_FORECAST_JSON=web/public/data/forecasts.json
